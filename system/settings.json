{
  "version": 2,
  "onboarding": {
    "storage": {
      "mode": "memory-repo"
    },
    "pathRules": {
      "include": {
        "paths": [
          "AGENTS.md",
          "README.md",
          "skills/**",
          "system/**"
        ],
        "fileTypes": [
          ".json",
          ".md",
          ".py"
        ]
      },
      "exclude": {
        "paths": [
          "docs/**",
          "CODE_OF_CONDUCT.md",
          "CONTRIBUTING.md",
          "SECURITY.md",
          "LICENSE",
          "roadmap/**",
          ".cache/**",
          ".pytest_cache/**",
          ".venv/**"
        ],
        "fileTypes": [
          ".gif",
          ".jpeg",
          ".jpg",
          ".png",
          ".zip"
        ]
      }
    }
  },
  "crossRepo": {
    "allow": []
  }
}
