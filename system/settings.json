{
  "version": 2,
  "onboarding": {
    "storage": {
      "mode": "memory-repo"
    },
    "pathRules": {
      "include": {
        "paths": [
          "AGENTS.md",
          "README.md",
          "installer/**",
          "runtime/**"
        ],
        "fileTypes": [
          ".json",
          ".md",
          ".py",
          ".sh"
        ]
      },
      "exclude": {
        "paths": [
          "docs/**",
          "CODE_OF_CONDUCT.md",
          "CONTRIBUTING.md",
          "SECURITY.md",
          "LICENSE",
          "roadmap/**",
          "node_modules/**",
          "vendor/**",
          "dist/**",
          "build/**",
          "coverage/**",
          ".cache/**",
          ".pytest_cache/**",
          ".venv/**",
          ".idea/**",
          ".vscode/**",
          ".env",
          ".env.*",
          "**/generated/**",
          "**/*.generated.*",
          "**/*.Zone.Identifier",
          "**/*:Zone.Identifier"
        ],
        "fileTypes": [
          ".gif",
          ".jpeg",
          ".jpg",
          ".png",
          ".zip"
        ]
      }
    }
  },
  "crossRepo": {
    "allow": []
  }
}
